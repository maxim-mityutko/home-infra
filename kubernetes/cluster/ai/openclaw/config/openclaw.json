{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "trustedProxies": [
      "10.1.0.0/16"
    ],
    "auth": {
      "mode": "trusted-proxy",
      "trustedProxy": {
        "userHeader": "x-authentik-email",
        "requiredHeaders": ["x-authentik-uid"]
      },
      "password": "${OPENCLAW_GATEWAY_PASSWORD}"
    },
    "controlUi": {
      "enabled": true,
      "allowedOrigins": [
        "https://openclaw.brhd.io"
      ],
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "https://ollama.com",
        "apiKey": "OLLAMA_API_KEY",
        "api": "ollama",
        "timeoutSeconds": 300,
        "models": [
          {
            "id": "gemma4:31b-cloud",
            "name": "gemma4:31b-cloud",
            "reasoning": true
          },
          {
            "id": "minimax-m2.7:cloud",
            "name": "minimax-m2.7:cloud",
            "reasoning": true
          },
          {
            "id": "kimi-k2.6:cloud",
            "name": "kimi-k2.6:cloud",
            "reasoning": true
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": {
        "primary": "ollama/gemma4:31b-cloud",
        "fallbacks": [
          "kimi-k2.6:cloud"
        ]
      }
    },
    "list": [
      {
        "id": "default",
        "name": "OpenClaw Assistant",
        "workspace": "~/.openclaw/workspace"
      }
    ]
  },
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 1,
    "sessionRetention": "24h",
    "runLog": {
      "maxBytes": "5mb",
      "keepLines": 10000
    }
  },
  "commands": {
    "config": true,
    "mcp": true,
    "plugins": true
  },
  "plugins": {
    "allow": [
      "ollama",
      "memory-core",
      "active-memory",
      "telegram",
      "browser",
      "memory-wiki"
    ],
    "deny": [],
    "entries": {
      "memory-core": {
        "config": {
          "dreaming": {
            "enabled": true
          }
        }
      },
      "active-memory": {
        "enabled": true,
        "config": {
          "enabled": true,
          "agents": ["default"],
          "allowedChatTypes": ["direct"],
          "queryMode": "recent",
          "promptStyle": "balanced",
          "persistTranscripts": false,
          "logging": true
        }
      },
      "memory-wiki": {
        "enabled": true,
        "config": {
          "vaultMode": "isolated",
          "vault": {
            "path": "~/.openclaw/wiki/main",
            "renderMode": "obsidian"
          },
          "obsidian": {
            "enabled": true,
            "useOfficialCli": false,
            "vaultName": "OpenClaw Wiki",
            "openAfterWrites": false
          },
          "bridge": {
            "enabled": false,
            "readMemoryArtifacts": true,
            "indexDreamReports": true,
            "indexDailyNotes": true,
            "indexMemoryRoot": true,
            "followMemoryEvents": true
          },
          "ingest": {
            "autoCompile": true,
            "maxConcurrentJobs": 1,
            "allowUrlIngest": true
          },
          "search": {
            "backend": "shared",
            "corpus": "wiki"
          },
          "context": {
            "includeCompiledDigestPrompt": false
          },
          "render": {
            "preserveHumanBlocks": true,
            "createBacklinks": true,
            "createDashboards": false
          }
        }
      }
    }
  },
  "tools": {
    "deny": [
      "canvas"
    ]
  },
  "channels": {
    "discord": {
      "enabled": false
    },
    "whatsapp": {
      "enabled": false
    },
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groups": { "*": { "requireMention": true } }
    },
    "slack": {
      "enabled": false
    },
    "signal": {
      "enabled": false
    }
  },
  "browser": {
    "enabled": true,
    "ssrfPolicy": {
      "dangerouslyAllowPrivateNetwork": false,
      "allowedHostnames": [
        "browserless.ai.svc.cluster.local."
      ]
    },
    "defaultProfile": "browserless",
    "profiles": {
      "browserless": {
        "cdpUrl": "ws://browserless.ai.svc.cluster.local.:3000?token=${BROWSERLESS_API_KEY}&timeout=120000",
        "color": "#4285F4"
      }
    }
  }
}
