{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 18789,
    "trustedProxies": [
      "10.1.0.0/16"
    ],
    "auth": {
      "mode": "trusted-proxy",
      "trustedProxy": {
        "userHeader": "x-authentik-email",
        "requiredHeaders": [
          "x-authentik-uid"
        ]
      }
    },
    "controlUi": {
      "enabled": true,
      "allowedOrigins": [
        "https://openclaw.brhd.io"
      ],
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "https://ollama.com",
        "apiKey": "OLLAMA_API_KEY",
        "api": "ollama",
        "timeoutSeconds": 300,
        "models": [
          {
            "id": "gemma4:31b-cloud",
            "name": "gemma4:31b-cloud",
            "reasoning": true,
            "input": [
              "text",
              "image"
            ]
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "model": {
        "primary": "ollama/gemma4:31b-cloud",
        "fallbacks": [
          "kimi-k2.6:cloud"
        ]
      }
    },
    "list": [
      {
        "id": "default",
        "name": "OpenClaw Assistant",
        "workspace": "~/.openclaw/workspace"
      }
    ]
  },
  "cron": {
    "enabled": false
  },
  "commands": {
    "config": true,
    "mcp": true,
    "plugins": true
  },
  "plugins": {
    "allow": [
      "ollama",

      "memory-core",
      "active-memory",

      "clawhub:@openclaw/discord",
      "clawhub:@openclaw/whatsapp",
      "telegram"
    ]
  },
  "channels": {
    "discord": {
      "enabled": true
    },
    "whatsapp": {
      "enabled": true
    },
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groups": { "*": { "requireMention": true } }
    },
    "slack": {
      "enabled": false
    },
    "signal": {
      "enabled": false
    }
  }
}
